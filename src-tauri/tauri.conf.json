{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clash-yaml-builder",
  "version": "0.2.4",
  "identifier": "com.robinzc2008.clash-yaml-builder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "clash-yaml-builder",
        "width": 1320,
        "height": 900,
        "minWidth": 980,
        "minHeight": 720,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": false,
    "windows": {
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
